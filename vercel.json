{
  "routes": [
    {
      "src": "/api/POS/(.*)",
      "dest": "http://hrg7408-001-site1.jtempurl.com/api/POS/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/api/GStock/(.*)",
      "dest": "http://hrg7408-001-site1.jtempurl.com/api/GStock/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*\\.html)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
